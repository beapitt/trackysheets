import React, { useState, useEffect } from 'react';

export default function CookieBanner() {
  const [isVisible, setIsVisible] = useState(false);

  useEffect(() => {
    const consent = localStorage.getItem('cookie-consent');
    if (!consent) {
      setIsVisible(true);
    }
  }, []);

  const acceptCookies = () => {
    localStorage.setItem('cookie-consent', 'true');
    setIsVisible(false);
  };

  if (!isVisible) return null;

  return (
    <div className="fixed bottom-0 left-0 right-0 bg-[#14532d] text-white p-4 z-[100] shadow-lg border-t border-green-700 font-sans">
      <div className="max-w-7xl mx-auto flex flex-col md:flex-row items-center justify-between gap-4 text-left">
        <div className="text-sm opacity-90 leading-relaxed m-0">
          This website uses cookies to ensure you get the best experience. By continuing, you agree to our 
          <a href="/privacy" className="text-white underline ml-1 hover:text-green-300">Privacy Policy</a>
        </div>
        <button 
          onClick={acceptCookies}
          className="bg-[#facc15] hover:bg-yellow-500 text-gray-900 font-bold py-2 px-6 rounded text-xs uppercase tracking-widest transition flex-shrink-0 border-none cursor-pointer"
        >
          Accept
        </button>
      </div>
    </div>
  );
}
